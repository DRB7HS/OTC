local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")


task.spawn(function()
    pcall(function()
        local folder = "7Z_Sounds"
        local fileName = "sounds.mp3"
        local soundPath = folder .. "/" .. fileName

        local assetFunc = getsynasset or getcustomasset

        if not assetFunc then
            warn("Executor does not support custom assets.")
            return
        end

        if not isfolder(folder) then
            makefolder(folder)
        end

        if not isfile(soundPath) then
            writefile(
                soundPath,
                game:HttpGet("https://files.catbox.moe/5a9cjr.mp3")
            )
        end

        local sound = Instance.new("Sound")
        sound.SoundId = assetFunc(soundPath)
        sound.Volume = 5
        sound.Parent = game:GetService("SoundService")

        sound:Play()
        task.wait(13)
        sound:Stop()
        sound:Destroy()
    end)
end)

